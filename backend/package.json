{
  "name": "horario-ups-backend",
  "version": "1.0.0",
  "description": "University schedule management system backend API",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && prisma db push --accept-data-loss && tsc",
    "start": "node dist/index.js",
    "db:push": "prisma db push",
    "db:seed": "tsx seed.ts",
    "db:studio": "prisma studio"
  },
  "keywords": [
    "hono",
    "prisma",
    "postgresql",
    "schedule"
  ],
  "author": "Universidad Politécnica Salesiana",
  "license": "ISC",
  "dependencies": {
    "@hono/node-server": "^1.19.12",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "hono": "^4.12.10",
    "ical-generator": "^10.1.0",
    "jsonwebtoken": "^9.0.3",
    "prisma": "^5.22.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
